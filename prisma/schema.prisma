// ATENÇÃO: este schema é COMPARTILHADO com o projeto `conect-crm` (banco
// Postgres único). Toda mudança aqui PRECISA ser refletida no schema do
// conect-crm, senão o `prisma db push` de um app vai detectar tabelas
// "estranhas" e falhar (ou pior: dropar dados se --accept-data-loss).
//
// Regras pra evitar perda de dados:
// 1. NUNCA usar --accept-data-loss em produção.
// 2. Adicionar novos models nos DOIS projetos antes de qualquer deploy.
// 3. Remoção de campos: fazer com migration e backup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PersonRole {
  id        String    @id @default(cuid())
  key       String    @unique
  label     String
  color     String    @default("#6366f1")
  bgColor   String    @default("#eef2ff")
  level     Int       @default(0)
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Direction {
  IN
  OUT
}

enum DispatchStatus {
  PENDING
  SENDING
  DONE
  FAILED
}

model Contact {
  id              String     @id @default(cuid())
  name            String
  phone           String     @unique
  email           String?
  roleId          String
  role            PersonRole @relation(fields: [roleId], references: [id])
  parentId        String?
  parent          Contact?   @relation("Hierarchy", fields: [parentId], references: [id])
  children        Contact[]  @relation("Hierarchy")

  dataNascimento  DateTime?
  genero          String?
  rua             String?
  bairro          String?
  cidade          String?
  zona            String?

  score           Float?
  score1          Float?
  score2          Float?
  score3          Float?
  scoreNote       String?

  lastContactAt   DateTime?
  lastMessage     String?
  notes           String?
  externalId      String?
  labels          String[]   @default([])
  source          String     @default("message")
  profilePhotoUrl String?

  customFields    Json?                                // valores dos campos personalizados
  contactNotes    ContactNote[]
  birthdayMessages BirthdayMessage[]

  conversations Conversation[]
  groupMembers  GroupMember[]
  demandas           Demanda[]        @relation("ContactDemandas")
  agendaSolicitante  AgendaEvento[]   @relation("AgendaSolicitante")
  agendaAnfitrioes   AgendaAnfitriao[] @relation("ContactAnfitrioes")

  reuniaoLider      Reuniao[]          @relation("ReuniaoLider")
  reuniaoAnfitrioes ReuniaoAnfitriao[] @relation("ReuniaoAnfitrioes")
  reuniaoPresentes  ReuniaoPresente[]  @relation("ReuniaoPresentes")
  reuniaoAvaliacoes ReuniaoAvaliacao[] @relation("ReuniaoAvaliadores")

  campaigns         CampaignContact[]  @relation("CampaignTargetContact")
  campaignsAssigned CampaignContact[]  @relation("CampaignAssignedTo")
  campaignsSent     CampaignContact[]  @relation("CampaignSentBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([cidade])
  @@index([zona])
  @@index([roleId])
  @@index([source])
}

model KanbanStatus {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  position  Int      @default(0)
  createdAt DateTime @default(now())

  conversations Conversation[]
}

model Label {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  bgColor   String   @default("#eef2ff")
  createdAt DateTime @default(now())
}

model Conversation {
  id              String       @id @default(cuid())
  contactId       String
  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  statusId        String
  status          KanbanStatus @relation(fields: [statusId], references: [id])
  whatsappChatId  String?
  lastMessageAt   DateTime?
  lastMessageText String?
  closedAt        DateTime?
  position        Int          @default(0)
  messages        Message[]
  demandas        Demanda[]
  reuniaoId       String?
  reuniao         Reuniao? @relation("ReuniaoConversas", fields: [reuniaoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId])
  @@index([statusId, position])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String
  direction      Direction    @default(OUT)
  whatsappMsgId  String?
  mediaType      String?
  rawData        Json?
  sentAt         DateTime     @default(now())
}

model ContactGroup {
  id          String        @id @default(cuid())
  name        String
  description String?
  date        DateTime?
  members     GroupMember[]
  dispatches  Dispatch[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  contactId String
  groupId   String
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([contactId, groupId])
}

model Dispatch {
  id        String           @id @default(cuid())
  groupId   String
  group     ContactGroup     @relation(fields: [groupId], references: [id])
  message   String
  status    DispatchStatus   @default(PENDING)
  sentAt    DateTime?
  results   DispatchResult[]
  createdAt DateTime         @default(now())
}

model AppConfig {
  key   String @id
  value String
}

model User {
  id        String    @id @default(cuid())
  name      String
  username  String?   @unique
  email     String?   @unique
  password  String
  isAdmin   Boolean   @default(false)
  modules   String[]  @default([])
  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contactNotes ContactNote[]
  auditLogs    AuditLog[]

  @@index([username])
}

/**
 * Log de auditoria — espelhado do conect-crm (schema compartilhado).
 * Painel-360 não grava; apenas mantém a tabela em sincronia.
 */
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String?
  action    String
  entity    String?
  entityId  String?
  summary   String?
  meta      Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Demanda {
  id            String   @id @default(cuid())
  titulo        String
  descricao     String?
  status        String   @default("ANALISAR")
  segmento      String?
  prioridade    String   @default("NORMAL")
  valor         Float?
  obs           String?
  lembrete      DateTime?
  prazo         DateTime?
  fechadaEm     DateTime?
  arquivadaEm   DateTime?

  solicitanteId String
  solicitante   Contact      @relation("ContactDemandas", fields: [solicitanteId], references: [id])
  conversaId    String?
  conversa      Conversation? @relation(fields: [conversaId], references: [id])

  agendas AgendaEvento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([solicitanteId])
  @@index([lembrete])
  @@index([arquivadaEm])
}

model AgendaCalendario {
  id        String         @id @default(cuid())
  nome      String
  cor       String         @default("#6366f1")
  isPadrao  Boolean        @default(false)
  createdAt DateTime       @default(now())
  eventos   AgendaEvento[]
}

model AgendaEvento {
  id                String  @id @default(cuid())
  titulo            String
  assunto           String?
  tipo              String  @default("AGENDA")
  status            String  @default("PENDENTE")
  inicio            DateTime
  duracao           Int?
  local             String?
  bairro            String?
  zona              String?
  quantidadePessoas Int?
  oQuePrecisa       String?
  notes             String?

  solicitanteId   String?
  solicitante     Contact? @relation("AgendaSolicitante", fields: [solicitanteId], references: [id])
  solicitanteNome String?
  solicitanteTel  String?

  demandaId    String?
  demanda      Demanda?          @relation(fields: [demandaId], references: [id])
  calendarioId String?
  calendario   AgendaCalendario? @relation(fields: [calendarioId], references: [id])

  anfitrioes AgendaAnfitriao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inicio])
  @@index([tipo])
  @@index([status])
  @@index([calendarioId])
}

model AgendaAnfitriao {
  id        String       @id @default(cuid())
  eventoId  String
  evento    AgendaEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact      @relation("ContactAnfitrioes", fields: [contactId], references: [id])
}

model Reuniao {
  id        String   @id @default(cuid())
  titulo    String
  dataHora  DateTime
  local     String?
  bairro    String?
  zona      String?
  status    String   @default("REALIZADA")
  notes     String?

  liderId   String?
  lider     Contact? @relation("ReuniaoLider", fields: [liderId], references: [id])

  anfitrioes ReuniaoAnfitriao[]
  presentes  ReuniaoPresente[]
  avaliacoes ReuniaoAvaliacao[]
  conversas  Conversation[]     @relation("ReuniaoConversas")
  campaigns  Campaign[]         @relation("CampaignReuniaoOrigin")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataHora])
  @@index([liderId])
}

model ReuniaoAnfitriao {
  id        String  @id @default(cuid())
  reuniaoId String
  reuniao   Reuniao @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation("ReuniaoAnfitrioes", fields: [contactId], references: [id])
}

model ReuniaoPresente {
  id        String   @id @default(cuid())
  reuniaoId String
  reuniao   Reuniao  @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation("ReuniaoPresentes", fields: [contactId], references: [id])
  nome      String?
  telefone  String?
  createdAt DateTime  @default(now())
}

model ReuniaoAvaliacao {
  id            String   @id @default(cuid())
  reuniaoId     String
  reuniao       Reuniao  @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  slot          Int
  avaliadorId   String?
  avaliador     Contact? @relation("ReuniaoAvaliadores", fields: [avaliadorId], references: [id])
  avaliadorNome String?
  atencao       Int      @default(0)
  interacao     Int      @default(0)
  obs           String?
}

model DispatchResult {
  id          String   @id @default(cuid())
  dispatchId  String
  dispatch    Dispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  contactId   String
  contactName String
  phone       String
  success     Boolean  @default(false)
  error       String?
  sentAt      DateTime @default(now())
}

// ─── Campanhas ─────────────────────────────────────────────────────────────────

model Campaign {
  id              String   @id @default(cuid())
  name            String
  description     String?
  goal            String?
  status          String   @default("ATIVA")
  messageTemplate String
  mediaUrl        String?
  mediaType       String?
  linkUrl         String?
  defaultDelayMs  Int      @default(2000)

  reuniaoOriginId String?
  reuniaoOrigin   Reuniao? @relation("CampaignReuniaoOrigin", fields: [reuniaoOriginId], references: [id], onDelete: SetNull)
  reuniaoMode     String?

  contacts        CampaignContact[]
  responseTags    CampaignResponseTag[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([reuniaoOriginId])
}

model CampaignContact {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact   @relation("CampaignTargetContact", fields: [contactId], references: [id], onDelete: Cascade)

  status        String    @default("PENDENTE")
  assignedToId  String?
  assignedTo    Contact?  @relation("CampaignAssignedTo", fields: [assignedToId], references: [id])
  sentById      String?
  sentBy        Contact?  @relation("CampaignSentBy", fields: [sentById], references: [id])
  sentAt        DateTime?
  sentMessage   String?

  responseTagId String?
  responseTag   CampaignResponseTag? @relation(fields: [responseTagId], references: [id])
  respondedAt   DateTime?
  notes         String?

  addedAt       DateTime  @default(now())

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([contactId])
}

model CampaignResponseTag {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  label      String
  color      String   @default("#6366f1")
  bgColor    String   @default("#eef2ff")
  order      Int      @default(0)
  contacts   CampaignContact[]

  @@index([campaignId])
}

// ─── Anotações e campos personalizados (usado no Painel 360) ───────────────────

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([createdAt])
}

model ContactCustomField {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  type      String   @default("text")
  options   String[] @default([])
  required  Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

model BirthdayMessage {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  year      Int
  message   String
  sentAt    DateTime @default(now())

  @@unique([contactId, year])
  @@index([sentAt])
}
